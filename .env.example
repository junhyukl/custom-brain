PORT=3001
OLLAMA_URL=http://localhost:11434
QDRANT_URL=http://localhost:6333
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=custom_brain
VISION_MODEL=llava
# Optional: default 2000, max 2048. If still "context length" error try 1000
# EMBED_MAX_INPUT_CHARS=1000

# Optional: upload to S3 instead of local brain-data (set S3_BUCKET to enable)
# S3_BUCKET=my-bucket
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
